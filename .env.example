# Copy this file to ".env" and fill in your real values.
# The .env file is private — it is never committed or shared.

# --- Claude (the brain) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- OpenAI (optional) ---
# Only needed to transcribe uploaded lecture RECORDINGS (audio/video) with Whisper.
# Leave blank to disable audio ingestion; pasting/uploading a transcript still works.
OPENAI_API_KEY=

# --- Canvas (UW) ---
CANVAS_BASE_URL=https://canvas.uw.edu/api/v1
CANVAS_TOKEN=

# --- Demo mode ---
# Set DEMO_MODE=true to serve a fake sample student (classes, grades, due dates,
# syllabi) instead of a real Canvas account — for a public "try it live" link.
# In demo mode CANVAS_TOKEN is ignored / not required. Leave blank for real use.
DEMO_MODE=

# --- Twilio (texting) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # your Twilio phone number, e.g. +12065550123

# --- You ---
MY_PHONE_NUMBER=           # your personal phone, the only number allowed, e.g. +12065559876

# --- Web address of this app (for study-page links) ---
# When running locally with a tunnel, use the tunnel URL (e.g. https://abc123.ngrok.io).
# When deployed, use your host URL (e.g. https://yourapp.up.railway.app).
PUBLIC_BASE_URL=http://localhost:8000

# --- Where local data files live (conversation history, study pages, reminders) ---
DATA_DIR=./data
